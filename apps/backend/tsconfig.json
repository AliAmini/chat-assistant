{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node10",
    "lib": ["ES2021"],
    "types": ["node"],
    // "ignoreDeprecations": "6.0",

    // Output settings
    "outDir": "./dist",
    "removeComments": true,

    // Monorepo path mapping
    "paths": {
      "@aichat/prisma": ["../../packages/prisma/dist/index.d.ts"],
      "@aichat/types": ["../../packages/types"]
    },

    // Type safety & decorators
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}
